{
	"name": "cordn-web",
	"private": true,
	"version": "0.2.0-next.2",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "node scripts/write-version.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check ./src && eslint ./src",
		"lint:check": "prettier --check src/ && eslint src/",
		"lint:fix": "prettier --write src/ && eslint --fix src/",
		"format": "prettier --write ./src",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"version": "node scripts/changelog.mjs",
		"android": "pnpm build && npx cap sync android && npx cap open android",
		"android:apk": "pnpm build && npx cap sync android && cd android && ./gradlew assembleDebug && echo 'APK dir: android/app/build/outputs/apk/debug/'",
		"android:release": "pnpm build && npx cap sync android && cd android && ./gradlew assembleRelease && echo 'APK dir: android/app/build/outputs/apk/release/'"
	},
	"devDependencies": {
		"@capacitor/assets": "^3.0.5",
		"@capacitor/cli": "^8.4.2",
		"@eslint/compat": "latest",
		"@eslint/js": "latest",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.22.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.10",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"paneforge": "^1.0.2",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.56.6",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.1.5",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@capacitor/android": "^8.4.2",
		"@capacitor/app": "^8.1.1",
		"@capacitor/core": "^8.4.2",
		"@capacitor/local-notifications": "^8.2.1",
		"@capacitor/splash-screen": "^8.0.2",
		"@capacitor/status-bar": "^8.0.3",
		"@contextvm/mcp-sdk": "^1.30",
		"@contextvm/sdk": "^0.13.9",
		"@noble/ciphers": "2.2.0",
		"@noble/hashes": "2.0.1",
		"@tanstack/svelte-query": "^6.1.33",
		"@tanstack/svelte-virtual": "^3.13.25",
		"applesauce-accounts": "^6",
		"applesauce-common": "^6",
		"applesauce-core": "^6",
		"applesauce-loaders": "^6",
		"applesauce-relay": "^6",
		"applesauce-signers": "^6",
		"cordn-background": "workspace:*",
		"lean-qr": "^2.7.1",
		"mode-watcher": "^1.1.0",
		"nostr-signer-capacitor-plugin": "^0.0.5",
		"nostr-tools": "^2.23.9",
		"qr-scanner": "^1.4.2",
		"svelte-sonner": "^1.1.1",
		"ts-mls": "2.0.0-rc.13",
		"zod": "^4.4.3"
	},
	"pnpm": {
		"overrides": {
			"nostr-tools": "^2.23.9",
			"tar": "^7.5.16",
			"minimatch": "^3.1.4",
			"uuid": "^11.1.1",
			"ws": "^8.21.0"
		},
		"onlyBuiltDependencies": [
			"sharp"
		],
		"patchedDependencies": {
			"nostr-signer-capacitor-plugin@0.0.5": "patches/nostr-signer-capacitor-plugin@0.0.5.patch",
			"applesauce-accounts@6.0.0": "patches/applesauce-accounts@6.0.0.patch",
			"applesauce-signers@6.0.1": "patches/applesauce-signers@6.0.1.patch"
		}
	}
}
