		"@tanstack/svelte-virtual": "^3.13.25",
		"applesauce-accounts": "^6.0.0",
		"applesauce-common": "^6.0.2",
		"applesauce-core": "^6.0.3",
		"applesauce-loaders": "^6.0.0",
		"applesauce-relay": "^6.0.3",
		"applesauce-signers": "^6.0.1",
		"client": "link:@modelcontextprotocol/sdk/client",
		"lean-qr": "^2.7.1",
		"mode-watcher": "^1.1.0",
		"nostr-tools": "^2.23.3",
